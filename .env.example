# Copy to `.env` for local development — never commit real secrets.
#   cp .env.example .env

# Shared
NODE_ENV=development
DATABASE_URL=postgresql://rpm:rpm@localhost:5433/rpm?schema=public

# API
API_HOST=0.0.0.0
API_PORT=3001
APP_VERSION=0.0.0
GIT_SHA=local-dev
WEB_ORIGIN=http://localhost:3000

# Worker
WORKER_HEALTH_HOST=0.0.0.0
WORKER_HEALTH_PORT=3002

# Web (Next.js)
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001

# Redis (optional — readiness currently reports skipped even when set)
REDIS_URL=redis://localhost:6379

# S3-compatible object storage (MinIO via Compose).
# If any of these are unset, the API falls back to local disk under `.data/object-storage/`.
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=rpm-dev
S3_ACCESS_KEY_ID=local-dev
S3_SECRET_ACCESS_KEY=local-dev-secret
S3_REGION=us-east-1

# Auth / JWT (defaults exist for local only; rotate for any shared environment)
JWT_SECRET=dev-only-change-me-in-production-32chars-min
JWT_ISSUER=rpm-api
JWT_AUDIENCE=rpm-api
TOKEN_HASH_PEPPER=dev-token-pepper-change-me
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_DAYS=30
REFRESH_COOKIE_PATH=/v1/auth
AUTH_COOKIE_SAME_SITE=lax
# AUTH_COOKIE_DOMAIN=localhost
AUTH_EMAIL_DELIVERY_MODE=console
META_DEMO_ENABLED=false

# Payments sandbox webhooks (local)
PAYMENTS_WEBHOOK_SECRET=local-dev-webhook-secret
# Keep false for local parity with fail-closed webhook verification
PAYMENTS_WEBHOOK_ALLOW_DEFAULT_SECRET=false

# RBAC catalog is seeded on API boot (set false only for special test runs)
# RBAC_SEED_ON_BOOT=true

# Demo seeds (optional overrides)
# DEMO_ORGANIZATION_ID=
# LOCAL_BOOTSTRAP_EMAIL=owner@localhost.dev
# LOCAL_BOOTSTRAP_PASSWORD=LocalDevPassword123!

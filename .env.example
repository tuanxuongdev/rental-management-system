# Copy only — never commit real secrets.

# Shared
NODE_ENV=development
DATABASE_URL=postgresql://rpm:rpm@localhost:5433/rpm?schema=public

# API
API_HOST=0.0.0.0
API_PORT=3001
APP_VERSION=0.0.0
GIT_SHA=local-dev

# Worker
WORKER_HEALTH_HOST=0.0.0.0
WORKER_HEALTH_PORT=3002

# Web (Next.js)
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001

# Redis (optional — readiness soft check when set)
REDIS_URL=redis://localhost:6379

# S3-compatible object storage (staging wiring — no uploads UI in Sprint-02)
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=rpm-dev
S3_ACCESS_KEY_ID=local-dev
S3_SECRET_ACCESS_KEY=local-dev
S3_REGION=us-east-1

# Auth cookies (Sprint-03+)
# AUTH_COOKIE_DOMAIN=localhost

# Auth / JWT (required in non-dev; defaults exist for local only)
JWT_SECRET=dev-only-change-me-in-production-32chars-min
JWT_ISSUER=rpm-api
JWT_AUDIENCE=rpm-api
TOKEN_HASH_PEPPER=dev-token-pepper-change-me
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_DAYS=30
REFRESH_COOKIE_PATH=/v1/auth
AUTH_COOKIE_SAME_SITE=lax
AUTH_EMAIL_DELIVERY_MODE=console
META_DEMO_ENABLED=false
WEB_ORIGIN=http://localhost:3000
